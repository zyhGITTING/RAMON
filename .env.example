# 部署前：把这个文件复制一份改名为 .env，然后把下面几项都填成真实值。
# docker-compose.yml 会自动读取同目录下的 .env 文件。

# PostgreSQL 启动/运维账号 datamid_owner 的密码。只供初始化、迁移、备份和恢复使用，
# 不会传给后端应用。必须与 DATAMID_DB_PASSWORD 不同。
DATAMID_DB_ADMIN_PASSWORD=请改成另一个强密码

# PostgreSQL 运行账号 datamid_app 的密码（自己起一个，不要用默认值）
DATAMID_DB_PASSWORD=请改成一个强密码

# 登录令牌签名密钥，必须是随机字符串，长度不能小于 32 位，否则后端启动会直接报错退出。
# Linux/Mac 生成命令：openssl rand -hex 32
# Windows PowerShell 生成命令：-join ((48..57)+(97..102)|Get-Random -Count 32|%{[char]$_})
DATAMID_TOKEN_SECRET=请改成至少32位的随机字符串

# 炎黄平台（或其他官方接口）统一认证 Token，用于 ERP/SRM/库存这几个内置数据源
DATAMID_RAMON_AUTH=

# ERP 托工明细表接口地址（可选，留空则使用文档中的默认地址）
DATAMID_ERP_SUBCONTRACT_URL=https://www.ramon.net.cn/api/ramon-api/aiagent/getERPSubcontractDetail

# 服务器对外访问地址。按当前 nginx 配置（挂到 /data_center/），格式为：
# http://服务器IP或域名:端口/data_center
DATAMID_PUBLIC_URL=http://172.17.111.60:8095/data_center

# MCP 查询默认/最大分页大小。默认值和最大值都设为 200，让单次调用能返回更多匹配结果。
DATAMID_MCP_DEFAULT_PAGE_SIZE=200
DATAMID_MCP_MAX_PAGE_SIZE=200

# 首次部署必填！用来自动创建第一个管理员账号（工号 10001 / 用户名 admin），至少 8 位。
DATAMID_INIT_ADMIN_PASSWORD=

# 是否允许普通用户自助注册账号，不填/留空 = 关闭（默认更安全）。要开启就填 true
DATAMID_ALLOW_SELF_REGISTER=

# 出站请求默认只允许解析到公网地址的 HTTPS URL。
# 可信内网或 HTTP 接口必须在这里逐个填写“精确主机名/IP”，逗号分隔；
# 不支持通配符、域名后缀、CIDR、URL 或端口。例如：
# DATAMID_OUTBOUND_ALLOW_HOSTS=erp.internal.example,llm.internal.example,10.20.0.15
DATAMID_OUTBOUND_ALLOW_HOSTS=

# 自动备份目录。生产环境请改为独立磁盘、NFS，或会同步到对象存储的宿主机目录。
DATAMID_BACKUP_DIR=./backups
DATAMID_BACKUP_INTERVAL_SECONDS=86400
DATAMID_LOGICAL_BACKUP_RETENTION_DAYS=14
DATAMID_PITR_BASEBACKUP_INTERVAL_SECONDS=604800
DATAMID_PITR_BASEBACKUP_RETENTION_DAYS=14
DATAMID_PITR_WAL_RETENTION_DAYS=21
DATAMID_RESTORE_VERIFY_INTERVAL_SECONDS=604800
